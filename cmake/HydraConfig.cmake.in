@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Drogon CONFIG QUIET)
if(NOT Drogon_FOUND)
	find_dependency(drogon CONFIG REQUIRED)
endif()

find_dependency(JsonCpp CONFIG QUIET)
if(NOT JsonCpp_FOUND)
	find_dependency(jsoncpp CONFIG REQUIRED)
endif()

if(TARGET JsonCpp::JsonCpp AND NOT TARGET jsoncpp_lib)
	add_library(jsoncpp_lib INTERFACE IMPORTED)
	target_link_libraries(jsoncpp_lib INTERFACE JsonCpp::JsonCpp)
elseif(TARGET jsoncpp::jsoncpp AND NOT TARGET jsoncpp_lib)
	add_library(jsoncpp_lib INTERFACE IMPORTED)
	target_link_libraries(jsoncpp_lib INTERFACE jsoncpp::jsoncpp)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/HydraStackTargets.cmake")

set(_hydra_public_dependency_targets)
if(TARGET Drogon::Drogon)
	list(APPEND _hydra_public_dependency_targets Drogon::Drogon)
elseif(TARGET drogon::drogon)
	list(APPEND _hydra_public_dependency_targets drogon::drogon)
endif()
if(TARGET JsonCpp::JsonCpp)
	list(APPEND _hydra_public_dependency_targets JsonCpp::JsonCpp)
elseif(TARGET jsoncpp::jsoncpp)
	list(APPEND _hydra_public_dependency_targets jsoncpp::jsoncpp)
elseif(TARGET jsoncpp_lib)
	list(APPEND _hydra_public_dependency_targets jsoncpp_lib)
endif()
foreach(_hydra_target IN ITEMS HydraStack::hydra_engine HydraStack::hydra_shell_engine)
	if(TARGET ${_hydra_target} AND _hydra_public_dependency_targets)
		set_property(TARGET ${_hydra_target} APPEND PROPERTY INTERFACE_LINK_LIBRARIES ${_hydra_public_dependency_targets})
	endif()
endforeach()
unset(_hydra_target)
unset(_hydra_public_dependency_targets)

check_required_components(HydraStack)
